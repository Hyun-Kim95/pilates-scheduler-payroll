PORT=4000
FRONTEND_URL=http://localhost:5173

# Database (전용 계정 pilates_app 사용 권장)
DB_HOST=localhost
DB_PORT=3306
DB_USER=pilates_app
DB_PASSWORD=여기에_원하는_비밀번호
DB_NAME=pilates_scheduler

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ========== Kakao Alimtalk (선택) ==========
# 상세 설정: docs/ALIMTALK.md 참고
# 1) 카카오 비즈니스 또는 파트너사 가입 → 발신번호·템플릿 등록·승인
# 2) API URL·API 키 확인 후 아래에 입력
# 3) 템플릿 변수명: 회원명, 날짜, 시간, 강사명 (예약확정에만 강사명)
KAKAO_ALIMTALK_ENABLED=false
KAKAO_ALIMTALK_API_URL=
KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_TEMPLATE_CONFIRMED=
KAKAO_ALIMTALK_TEMPLATE_CANCELLED=
KAKAO_ALIMTALK_TEMPLATE_REMINDER=
